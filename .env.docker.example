# Copy this file to .env before running docker compose:
#   cp .env.docker.example .env
#
# docker-compose.yml loads this whole file into the app container via `env_file`, and
# NEXT_PUBLIC_GOOGLE_CLIENT_ID is additionally passed through as a build arg (see
# docker-compose.yml `build.args`) because Next.js inlines NEXT_PUBLIC_* values into the
# client bundle at build time, not at container start time.

# --- Required ---

# Long random secret used to sign session cookies. Generate one with:
#   openssl rand -base64 48
AUTH_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# Admin account seeded into the database the first time the app starts.
ADMIN_EMAIL="admin@stocksense.local"
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
ADMIN_NAME="StockSense Admin"
ADMIN_MOBILE="9999999999"

# --- Optional: AI narrative (falls back to a deterministic summary if unset) ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3-flash-preview"

# --- Optional: Google Sign-In ---
# NEXT_PUBLIC_GOOGLE_CLIENT_ID is also read as a docker compose build arg - if you change
# it, rebuild the image (`docker compose up -d --build`) rather than just restarting.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""

# --- Optional: UPI payment details shown on the /upgrade page ---
UPI_ID=""
UPI_QR_IMAGE_URL=""

# --- Optional: SEC EDGAR fair-access contact (Fundamentals module, US symbols) ---
# SEC asks for a real identifying contact in the User-Agent header rather than a generic
# one - see https://www.sec.gov/os/webmaster-faq#developers
SEC_EDGAR_CONTACT=""

# --- Durable storage (only used when running with docker-compose.durable.yml) ---
# Shared secret between the app and the self-hosted Redis-REST proxy. Only needs to be
# set explicitly if the stack is reachable outside your own machine.
SRH_TOKEN="CHANGE_ME_LOCAL_TOKEN"
STOCKSENSE_DB_KEY="stocksense:db:v1"

# --- Misc ---
# Host port the app is published on (container always listens on 3000 internally).
APP_PORT=3000
