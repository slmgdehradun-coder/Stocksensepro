# GEMINI_API_KEY: Required for server-side Gemini AI API calls.
# Never expose this key with a NEXT_PUBLIC_ prefix.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional: override the Gemini text model used by server API routes.
GEMINI_MODEL="gemini-3-flash-preview"

# Google Sign-In OAuth client ID.
# This public client ID is needed by the browser Google button and is verified again on the server.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_ID=""

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# AUTH_SECRET: Required for signed HTTP-only login sessions in production.
# Use a long random value. Example generator: openssl rand -base64 48
AUTH_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

# Admin seed account used when the local JSON database is first created.
ADMIN_EMAIL="admin@stocksense.local"
ADMIN_PASSWORD="Admin@12345"
ADMIN_NAME="StockSense Admin"
ADMIN_MOBILE="9999999999"

# Optional local/demo JSON storage location. For production, replace the storage adapter with durable DB/KV.
STOCKSENSE_DB_PATH="./data/stocksense-db.json"

# Optional production durable storage. Use Vercel KV or Upstash Redis REST to persist users,
# sessions, subscriptions, payment requests, paper trading and settings across serverless restarts.
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
STOCKSENSE_DB_KEY="stocksense:db:v1"

# Optional default payment settings seeded into the local JSON store.
UPI_ID=""
UPI_QR_IMAGE_URL=""

# Optional: contact info sent in the User-Agent header for SEC EDGAR requests (Fundamentals
# module, US-listed symbols). SEC's fair-access policy asks for a real identifying contact
# rather than a generic/spoofed User-Agent - see https://www.sec.gov/os/webmaster-faq#developers
SEC_EDGAR_CONTACT=""
